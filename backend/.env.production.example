# Copy this file to .env.production and fill in real values
# NEVER commit .env.production to git

PORT=3001
NODE_ENV=production

# PostgreSQL
# Use your online/managed Postgres host here.
PG_HOST=CHANGE_ME_online_postgres_host
PG_PORT=5432
PG_DATABASE=jtl_analytics
PG_USER=jtl_api
PG_PASSWORD=CHANGE_ME_online_database_password
PG_SSL=true
PG_SSL_VERIFY=true
PG_POOL_MAX=5
PG_CONNECTION_TIMEOUT_MS=15000
PG_IDLE_TIMEOUT_MS=30000

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# JWT — generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=CHANGE_ME_64_char_random_string
JWT_REFRESH_SECRET=CHANGE_ME_different_64_char_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Frontend URL (your domain). Comma-separated list is supported for
# multi-origin setups (apex + www, IP + DNS, http + https during rollout).
# Example: FRONTEND_URL=https://dashboard.example.com,https://www.example.com
FRONTEND_URL=https://YOUR_DOMAIN

# Email / SMTP
# Configure with your provider, then set MAIL_ENABLED=true.
MAIL_ENABLED=false
MAIL_FROM="JTL Analytics <no-reply@YOUR_DOMAIN>"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_HELO_NAME=YOUR_DOMAIN

# Cookie settings
# Leave empty (recommended): cookie `secure` flag is set from the actual
#   request scheme (via X-Forwarded-Proto from the reverse proxy). This is
#   correct for both HTTP-only and HTTPS deployments without further tweaks.
# Set true  to force Secure cookies (HTTPS only).
# Set false to force non-Secure cookies (HTTP-only deploys behind a plain proxy).
COOKIE_SECURE=
# strict | lax | none
COOKIE_SAMESITE=strict
COOKIE_PATH=/
# COOKIE_DOMAIN=YOUR_DOMAIN

# Body size limit
BODY_LIMIT=10mb
JSON_MAX_DEPTH=6

# Ingest/retry tuning
INGEST_RETRY_MAX_ATTEMPTS=3
INGEST_RETRY_BASE_DELAY_MS=400
INGEST_BULK_ID_CHUNK=5000
INVENTORY_REQUIRE_SOURCE_METADATA=true
INVENTORY_ZERO_STOCK_POLICY=verify

# Health/detail tuning
HEALTH_TENANT_SAMPLE_LIMIT=200

# Maintenance
MATVIEW_REFRESH_INTERVAL_MINUTES=30

# Seeder
SUPER_ADMIN_EMAIL=superadmin@jtl.com
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_PASSWORD=CHANGE_ME_Strong_Admin_Password_123!
SUPER_ADMIN_RESET=false
