# Copy this file to backend/.env for local Docker/dev.
# Never commit real .env files.

PORT=3001
NODE_ENV=development

# PostgreSQL
# Docker Compose does not start a local Postgres container.
# Use your online/managed Postgres host here.
PG_HOST=CHANGE_ME_online_postgres_host
PG_PORT=5432
PG_DATABASE=jtl_analytics
PG_USER=jtl_api
PG_PASSWORD=CHANGE_ME_online_database_password
PG_SSL=true
PG_SSL_VERIFY=true
PG_POOL_MAX=5
PG_CONNECTION_TIMEOUT_MS=15000
PG_IDLE_TIMEOUT_MS=30000

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_local_redis_password

# JWT — generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=CHANGE_ME_64_char_random_access_secret
JWT_REFRESH_SECRET=CHANGE_ME_different_64_char_random_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Frontend origins. Comma-separated values are supported.
FRONTEND_URL=http://localhost:3000

# Email / SMTP
# Leave MAIL_ENABLED=false until SMTP is configured and tested.
MAIL_ENABLED=false
MAIL_FROM="JTL Analytics <no-reply@example.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_HELO_NAME=localhost

# Cookies
COOKIE_SECURE=
COOKIE_SAMESITE=strict
COOKIE_PATH=/
# COOKIE_DOMAIN=localhost

# Body/security limits
BODY_LIMIT=10mb
JSON_MAX_DEPTH=6

# Ingest/retry tuning
INGEST_RETRY_MAX_ATTEMPTS=3
INGEST_RETRY_BASE_DELAY_MS=400
INGEST_BULK_ID_CHUNK=5000
INVENTORY_REQUIRE_SOURCE_METADATA=true
INVENTORY_ZERO_STOCK_POLICY=verify

# Health/detail tuning
HEALTH_TENANT_SAMPLE_LIMIT=200

# Maintenance
MATVIEW_REFRESH_INTERVAL_MINUTES=30

# Seeder
SUPER_ADMIN_EMAIL=superadmin@jtl.com
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_PASSWORD=CHANGE_ME_Strong_Admin_Password_123!
SUPER_ADMIN_RESET=false
