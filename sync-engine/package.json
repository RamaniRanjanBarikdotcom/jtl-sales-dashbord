{
  "name": "jtl-sync-engine",
  "version": "1.0.0",
  "description": "JTL Analytics — Sync Engine: reads JTL MS SQL and pushes to backend API",
  "main": "dist/main.js",
  "bin": "dist/main.js",
  "scripts": {
    "build":     "tsc",
    "start":     "node dist/main.js",
    "dev":       "ts-node src/main.ts",
    "check":     "ts-node src/check.ts",
    "pm2":       "pm2 start ecosystem.config.js",
    "build:exe": "node build.js"
  },
  "pkg": {
    "scripts": [
      "dist/**/*.js"
    ],
    "assets": [
      "dist/ui/public/**/*",
      "node_modules/axios/**/*",
      "node_modules/mssql/**/*",
      "node_modules/tedious/**/*",
      "node_modules/ssh2/**/*",
      "node_modules/node-cron/**/*",
      "node_modules/winston/**/*",
      "node_modules/express/**/*"
    ],
    "targets": [
      "node18-win-x64",
      "node18-macos-x64",
      "node18-linux-x64"
    ],
    "outputPath": "release"
  },
  "dependencies": {
    "mssql":     "^10.0.4",
    "axios":     "^1.6.8",
    "node-cron": "^3.0.3",
    "dotenv":    "^16.4.5",
    "winston":   "^3.12.0",
    "express":   "^4.18.3",
    "cors":      "^2.8.5",
    "ssh2":      "^1.15.0",
    "open":      "^9.1.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg":     "^5.11.5",
    "typescript":       "^5.4.5",
    "@types/node":      "^20.12.7",
    "@types/mssql":     "^9.1.5",
    "@types/node-cron": "^3.0.11",
    "@types/express":   "^4.17.21",
    "@types/cors":      "^2.8.17",
    "ts-node":          "^10.9.2",
    "@types/ssh2":      "^1.15.0"
  }
}
