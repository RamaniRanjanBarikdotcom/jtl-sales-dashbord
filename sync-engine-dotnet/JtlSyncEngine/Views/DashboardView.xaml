<UserControl x:Class="JtlSyncEngine.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:JtlSyncEngine.Views"
             Background="#04060f">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <local:StringToBrushConverter x:Key="StrBrush"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer>
        <StackPanel Margin="28,24,28,24">

            <!-- Header -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Dashboard"
                           Foreground="#f1f5f9"
                           FontSize="22"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding SyncAllNowCommand}"
                        ToolTip="Trigger all sync modules immediately">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x21BB;" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Sync All Now" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Connection Status Bar -->
            <Border Background="#0a1628"
                    BorderBrush="#1e2d45"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16,12"
                    Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Connections"
                               Foreground="#64748b"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,20,0"/>

                    <!-- SQL Status -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                        <Ellipse Width="9" Height="9" Margin="0,0,7,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#f87171"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSqlConnected}" Value="True">
                                            <Setter Property="Fill" Value="#34d399"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="SQL Server" Foreground="#94a3b8" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- API Status -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                        <Ellipse Width="9" Height="9" Margin="0,0,7,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#f87171"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsApiConnected}" Value="True">
                                            <Setter Property="Fill" Value="#34d399"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="Backend API" Foreground="#94a3b8" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Style="{StaticResource SmallButton}"
                            Command="{Binding CheckConnectionsCommand}">
                        <TextBlock Text="{Binding ConnectionStatusText}" FontSize="12"/>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Module Cards - 2x2 Grid -->
            <UniformGrid Columns="2" Rows="2">

                <!-- Orders Card -->
                <Border Style="{StaticResource Card}" Margin="0,0,10,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="Orders"
                                           Foreground="#f1f5f9"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border Grid.Column="1"
                                    CornerRadius="12"
                                    Padding="10,4"
                                    Background="{Binding OrdersStatus.StatusColor, Converter={StaticResource StrBrush}}">
                                <TextBlock Text="{Binding OrdersStatus.StatusLabel}"
                                           Foreground="#ffffff" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Last sync" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding OrdersStatus.LastSyncDisplay}"
                                           Foreground="#f1f5f9" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Next sync" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding OrdersStatus.NextSyncDisplay}"
                                           Foreground="#f1f5f9" FontSize="13"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="2">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Rows synced: " Style="{StaticResource FieldLabel}" Margin="0"/>
                                <TextBlock Text="{Binding OrdersStatus.RowsSynced}"
                                           Foreground="#60a5fa" FontSize="12"/>
                            </StackPanel>
                            <TextBlock Text="{Binding OrdersStatus.StatusMessage}"
                                       Foreground="#64748b" FontSize="11" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding OrdersStatus.ProgressDisplay}"
                                       Foreground="#60a5fa" FontSize="11"
                                       Visibility="{Binding OrdersStatus.IsRunning, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>

                        <Button Grid.Row="3"
                                Style="{StaticResource SmallButton}"
                                Command="{Binding SyncOrdersNowCommand}"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0">
                            <TextBlock Text="Sync Now"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Products Card -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Products"
                                       Foreground="#f1f5f9" FontSize="16" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1" CornerRadius="12" Padding="10,4"
                                    Background="{Binding ProductsStatus.StatusColor, Converter={StaticResource StrBrush}}">
                                <TextBlock Text="{Binding ProductsStatus.StatusLabel}"
                                           Foreground="#ffffff" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Last sync" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding ProductsStatus.LastSyncDisplay}"
                                           Foreground="#f1f5f9" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Next sync" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding ProductsStatus.NextSyncDisplay}"
                                           Foreground="#f1f5f9" FontSize="13"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="2">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Rows synced: " Style="{StaticResource FieldLabel}" Margin="0"/>
                                <TextBlock Text="{Binding ProductsStatus.RowsSynced}"
                                           Foreground="#60a5fa" FontSize="12"/>
                            </StackPanel>
                            <TextBlock Text="{Binding ProductsStatus.StatusMessage}"
                                       Foreground="#64748b" FontSize="11" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding ProductsStatus.ProgressDisplay}"
                                       Foreground="#60a5fa" FontSize="11"
                                       Visibility="{Binding ProductsStatus.IsRunning, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>

                        <Button Grid.Row="3"
                                Style="{StaticResource SmallButton}"
                                Command="{Binding SyncProductsNowCommand}"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0">
                            <TextBlock Text="Sync Now"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Customers Card -->
                <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Customers"
                                       Foreground="#f1f5f9" FontSize="16" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1" CornerRadius="12" Padding="10,4"
                                    Background="{Binding CustomersStatus.StatusColor, Converter={StaticResource StrBrush}}">
                                <TextBlock Text="{Binding CustomersStatus.StatusLabel}"
                                           Foreground="#ffffff" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Last sync" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding CustomersStatus.LastSyncDisplay}"
                                           Foreground="#f1f5f9" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Next sync" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding CustomersStatus.NextSyncDisplay}"
                                           Foreground="#f1f5f9" FontSize="13"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="2">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Rows synced: " Style="{StaticResource FieldLabel}" Margin="0"/>
                                <TextBlock Text="{Binding CustomersStatus.RowsSynced}"
                                           Foreground="#60a5fa" FontSize="12"/>
                            </StackPanel>
                            <TextBlock Text="{Binding CustomersStatus.StatusMessage}"
                                       Foreground="#64748b" FontSize="11" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding CustomersStatus.ProgressDisplay}"
                                       Foreground="#60a5fa" FontSize="11"
                                       Visibility="{Binding CustomersStatus.IsRunning, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>

                        <Button Grid.Row="3"
                                Style="{StaticResource SmallButton}"
                                Command="{Binding SyncCustomersNowCommand}"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0">
                            <TextBlock Text="Sync Now"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Inventory Card -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Inventory"
                                       Foreground="#f1f5f9" FontSize="16" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1" CornerRadius="12" Padding="10,4"
                                    Background="{Binding InventoryStatus.StatusColor, Converter={StaticResource StrBrush}}">
                                <TextBlock Text="{Binding InventoryStatus.StatusLabel}"
                                           Foreground="#ffffff" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Last sync" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding InventoryStatus.LastSyncDisplay}"
                                           Foreground="#f1f5f9" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Next sync" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding InventoryStatus.NextSyncDisplay}"
                                           Foreground="#f1f5f9" FontSize="13"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="2">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Rows synced: " Style="{StaticResource FieldLabel}" Margin="0"/>
                                <TextBlock Text="{Binding InventoryStatus.RowsSynced}"
                                           Foreground="#60a5fa" FontSize="12"/>
                            </StackPanel>
                            <TextBlock Text="{Binding InventoryStatus.StatusMessage}"
                                       Foreground="#64748b" FontSize="11" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding InventoryStatus.ProgressDisplay}"
                                       Foreground="#60a5fa" FontSize="11"
                                       Visibility="{Binding InventoryStatus.IsRunning, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>

                        <Button Grid.Row="3"
                                Style="{StaticResource SmallButton}"
                                Command="{Binding SyncInventoryNowCommand}"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0">
                            <TextBlock Text="Sync Now"/>
                        </Button>
                    </Grid>
                </Border>

            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
