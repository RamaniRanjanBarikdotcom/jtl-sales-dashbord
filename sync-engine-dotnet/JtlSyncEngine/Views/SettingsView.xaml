<UserControl x:Class="JtlSyncEngine.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:JtlSyncEngine.Views"
             Background="#04060f"
             x:Name="settingsRoot">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <local:NotBooleanConverter x:Key="NotBool"/>
            <local:NotEmptyToVisibilityConverter x:Key="NotEmptyToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer>
        <StackPanel Margin="28,24,28,24">

            <!-- Header -->
            <TextBlock Text="Settings"
                       Foreground="#f1f5f9"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Margin="0,0,0,24"/>

            <!-- SQL Server Connection -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="SQL Server Connection" Style="{StaticResource SectionHeader}" Margin="0"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource SuccessButton}"
                                    Command="{Binding AutoDetectJtlCommand}"
                                    Padding="14,7"
                                    Margin="0,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x2605; " FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Text="Auto-Detect JTL" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{Binding AutoDetectResult}"
                               Foreground="{Binding AutoDetectColor}"
                               FontSize="12"
                               Margin="0,-8,0,12"
                               Visibility="{Binding AutoDetectResult, Converter={StaticResource NotEmptyToVis}}"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Host" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource DarkTextBox}"
                                     Text="{Binding SqlHost, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Port" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource DarkTextBox}"
                                     Text="{Binding SqlPort, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Database" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource DarkTextBox}"
                                 Text="{Binding SqlDatabase, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <CheckBox Style="{StaticResource DarkCheckBox}"
                              IsChecked="{Binding SqlWindowsAuth}"
                              Content="Use Windows Authentication"
                              Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Username" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource DarkTextBox}"
                                     Text="{Binding SqlUsername, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding SqlWindowsAuth, Converter={StaticResource NotBool}}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Password" Style="{StaticResource FieldLabel}"/>
                            <PasswordBox Style="{StaticResource DarkPasswordBox}"
                                         x:Name="sqlPasswordBox"
                                         IsEnabled="{Binding SqlWindowsAuth, Converter={StaticResource NotBool}}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource BaseButton}"
                                Command="{Binding TestSqlCommand}"
                                Margin="0,0,12,0">
                            <TextBlock Text="Test Connection"/>
                        </Button>
                        <TextBlock Text="{Binding SqlTestResult}"
                                   Foreground="{Binding SqlTestColor}"
                                   VerticalAlignment="Center"
                                   FontSize="13"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Backend API -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Backend API" Style="{StaticResource SectionHeader}"/>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Backend URL" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource DarkTextBox}"
                                 Text="{Binding BackendApiUrl, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="API Key" Style="{StaticResource FieldLabel}"/>
                            <PasswordBox Style="{StaticResource DarkPasswordBox}"
                                         x:Name="apiKeyBox"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Tenant ID" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource DarkTextBox}"
                                     Text="{Binding TenantId, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource BaseButton}"
                                Command="{Binding TestApiCommand}"
                                Margin="0,0,12,0">
                            <TextBlock Text="Test API"/>
                        </Button>
                        <TextBlock Text="{Binding ApiTestResult}"
                                   Foreground="{Binding ApiTestColor}"
                                   VerticalAlignment="Center"
                                   FontSize="13"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Sync Schedule -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Sync Schedule (interval in minutes)" Style="{StaticResource SectionHeader}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Column="0" Grid.Row="0">
                            <TextBlock Text="Orders (minutes)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource DarkTextBox}"
                                     Text="{Binding OrdersSyncInterval, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Grid.Row="0">
                            <TextBlock Text="Products (minutes)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource DarkTextBox}"
                                     Text="{Binding ProductsSyncInterval, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="0" Grid.Row="2">
                            <TextBlock Text="Customers (minutes)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource DarkTextBox}"
                                     Text="{Binding CustomersSyncInterval, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Grid.Row="2">
                            <TextBlock Text="Inventory (minutes)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource DarkTextBox}"
                                     Text="{Binding InventorySyncInterval, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Batch Settings -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Batch Settings" Style="{StaticResource SectionHeader}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Batch Size (rows per API call)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource DarkTextBox}"
                                     Text="{Binding BatchSize, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Batch Delay (ms between batches)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource DarkTextBox}"
                                     Text="{Binding BatchDelayMs, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- App Settings -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="App Settings" Style="{StaticResource SectionHeader}"/>

                    <CheckBox Style="{StaticResource DarkCheckBox}"
                              IsChecked="{Binding StartWithWindows}"
                              Content="Start with Windows"
                              Margin="0,0,0,12"/>

                    <CheckBox Style="{StaticResource DarkCheckBox}"
                              IsChecked="{Binding StartMinimized}"
                              Content="Start minimized"/>
                </StackPanel>
            </Border>

            <!-- Save Button -->
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveCommand}"
                        Padding="24,10"
                        FontSize="14"
                        Margin="0,0,16,0">
                    <TextBlock Text="Save Settings"/>
                </Button>
                <Button Style="{StaticResource BaseButton}"
                        Command="{Binding ResetWatermarksCommand}"
                        Padding="16,10"
                        FontSize="13"
                        Margin="0,0,16,0"
                        ToolTip="Deletes all watermark files so the next sync fetches ALL data from the last 2 years (full re-sync)">
                    <TextBlock Text="↺ Reset &amp; Full Sync"/>
                </Button>
                <TextBlock Text="{Binding SaveResult}"
                           Foreground="{Binding SaveResultColor}"
                           VerticalAlignment="Center"
                           FontSize="13"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
